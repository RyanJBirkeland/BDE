#!/bin/sh
# Skip full verification on delete-only pushes.
#
# Git's pre-push hook receives one line per ref on stdin:
#   <local ref> <local sha> <remote ref> <remote sha>
# For a delete push, <local sha> is 40 zeros. If every ref being pushed
# is a delete, there's no new code to verify — skip the test suite.
has_non_delete=""
zero_sha="0000000000000000000000000000000000000000"
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "$local_ref" ] && [ -z "$local_sha" ]; then continue; fi
  if [ "$local_sha" != "$zero_sha" ]; then
    has_non_delete=1
  fi
done

if [ -z "$has_non_delete" ]; then
  echo "pre-push: delete-only push, skipping verification"
  exit 0
fi

# Run typecheck and renderer tests in parallel.
# For agent/* branches, skip test:main (node-gyp rebuild + main-process vitest):
#   - node_modules is a symlink to the main checkout — node-gyp would rebuild
#     the shared native binary, racing with other agents pushing simultaneously
#   - CI runs test:main on every merge to main, providing the safety net
#   - Skipping saves ~50s per agent push
#
# test:main is still run for non-agent branches (manual pushes, main itself)
# via `npm run test:main`, which includes the pretest/posttest ABI rebuilds.
#
# The EXIT trap kills all background jobs when the hook finishes (success or
# failure). Without it, orphaned background jobs from a failed hook run can
# race with node-gyp on retries, corrupting the build directory.
cleanup() { kill $(jobs -p) 2>/dev/null || true; }
trap cleanup EXIT

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

# ---------------------------------------------------------------------------
# Native module rebuild — idempotent with on-disk cache.
#
# The better-sqlite3 build directory accumulates stale .deps/*.raw dependency
# files that node-gyp occasionally tries to read before writing, producing:
#   .deps/Release/obj.target/.../sqlite3.o.d.raw: No such file or directory
# Wiping .deps before every rebuild is the cheap, reliable fix.
#
# We also cache the compiled .node artifact under ~/.bde/native-cache keyed by
# (node version, electron version, better-sqlite3 version). If the key hits,
# we restore the binary in place and skip rebuild entirely.
# ---------------------------------------------------------------------------
rebuild_better_sqlite3() {
  module_root="node_modules/better-sqlite3"
  build_artifact="$module_root/build/Release/better_sqlite3.node"

  node_version=$(node --version 2>/dev/null || echo "unknown")
  electron_version=$(node -p "require('./package.json').devDependencies.electron" 2>/dev/null || echo "unknown")
  module_version=$(node -p "require('./package.json').dependencies['better-sqlite3']" 2>/dev/null || echo "unknown")
  cache_key="${node_version}-${electron_version}-${module_version}"
  cache_dir="$HOME/.bde/native-cache/$cache_key"
  cache_artifact="$cache_dir/better_sqlite3.node"

  if [ -f "$cache_artifact" ]; then
    echo "pre-push: native cache hit ($cache_key) — restoring better-sqlite3 binary"
    mkdir -p "$module_root/build/Release"
    cp "$cache_artifact" "$build_artifact"
    return 0
  fi

  echo "pre-push: native cache miss ($cache_key) — rebuilding better-sqlite3"
  rm -rf "$module_root/.deps" "$module_root/build"
  if ! ./node_modules/.bin/node-gyp rebuild --directory="$module_root"; then
    return 1
  fi

  if [ -f "$build_artifact" ]; then
    mkdir -p "$cache_dir"
    if ! cp "$build_artifact" "$cache_artifact" 2>/dev/null; then
      echo "pre-push: warning — failed to write native cache at $cache_artifact (continuing)"
    fi
  fi
  return 0
}

npm run typecheck &
PID_TYPECHECK=$!

npm test &
PID_TEST=$!

PID_MAIN=""
case "$current_branch" in
  agent/*)
    echo "pre-push: agent branch — skipping test:main (CI enforces it on merge)"
    ;;
  *)
    (rebuild_better_sqlite3 && \
      npx vitest run --config src/main/vitest.main.config.ts) &
    PID_MAIN=$!
    ;;
esac

FAIL=0
wait "$PID_TYPECHECK" || FAIL=1
wait "$PID_TEST"      || FAIL=1
[ -n "$PID_MAIN" ] && { wait "$PID_MAIN" || FAIL=1; }

[ "$FAIL" -eq 0 ] || exit 1
